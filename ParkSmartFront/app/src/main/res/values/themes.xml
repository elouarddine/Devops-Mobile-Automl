<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Theme principal (jour/nuit via values-night/*) -->
    <style name="Base.Theme.ParkSmart" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Brand -->
        <item name="colorPrimary">@color/ps_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/ps_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/ps_on_primary_container</item>

        <!-- Surfaces -->
        <item name="android:colorBackground">@color/ps_bg</item>
        <item name="colorSurface">@color/ps_surface</item>
        <item name="colorOnSurface">@color/ps_text</item>
        <item name="colorOutline">@color/ps_outline</item>

        <!-- Fenêtre -->
        <item name="android:windowBackground">@color/ps_bg</item>

        <!-- Status/Nav bars (jour) -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/ps_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>

        <!-- Styles par défaut (optionnel mais pratique pour un design cohérent) -->
        <item name="materialButtonStyle">@style/Widget.ParkSmart.Button</item>
        <item name="textInputStyle">@style/Widget.ParkSmart.TextInput</item>

        <!-- Empêche les previews Android Studio de casser sur les vieilles APIs -->
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <style name="Theme.ParkSmart" parent="Base.Theme.ParkSmart" />

    <!-- Bouton primaire -->
    <style name="Widget.ParkSmart.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
        <item name="backgroundTint">@color/ps_primary</item>
    </style>

    <!-- TextInput moderne -->
    <style name="Widget.ParkSmart.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/ps_outline</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxBackgroundColor">@color/ps_surface</item>
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="hintTextColor">@color/ps_text_muted</item>
    </style>



    <!-- Bottomsheet home style -->
    <style name="Widget.ParkSmart.FilterChip" parent="Widget.Material3.Chip.Filter">
        <item name="android:textSize">13sp</item>
        <item name="chipCornerRadius">999dp</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipStrokeColor">@color/ps_outline</item>
        <item name="chipBackgroundColor">@color/ps_chip_bg</item>
        <item name="android:textColor">@color/ps_text</item>
        <item name="checkedIconVisible">false</item>
    </style>




</resources>
