<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fond principal plus profond -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#08111F"
                android:centerColor="#0C1830"
                android:endColor="#050A14"
                android:type="linear" />
        </shape>
    </item>

    <!-- Halo central derrière le logo -->
    <item
        android:left="36dp"
        android:right="36dp"
        android:top="120dp"
        android:bottom="250dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:centerX="0.5"
                android:centerY="0.35"
                android:gradientRadius="240dp"
                android:startColor="#2A4C7DFF"
                android:centerColor="#142DD4BF"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- Petites lumières décoratives -->
    <item android:left="30dp" android:top="150dp" android:right="300dp" android:bottom="620dp">
