<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fond principal -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="@color/ps_bg_top"
                android:endColor="@color/ps_bg_bottom"
                android:type="linear" />
        </shape>
    </item>

    <!-- Halo haut centre -->
    <item
        android:left="30dp"
        android:right="30dp"
        android:top="40dp"
        android:bottom="500dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:centerX="0.5"
                android:centerY="0.3"
                android:gradientRadius="220dp"
                android:startColor="#264C7DFF"
                android:centerColor="#162DD4BF"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- Blob gauche -->
    <item
        android:left="-50dp"
        android:top="140dp">
        <shape android:shape="oval">
            <size
                android:width="160dp"
                android:height="160dp" />
            <solid android:color="#164C7DFF" />
        </shape>
    </item>

    <!-- Blob droite -->
    <item
        android:right="-40dp"
        android:top="210dp">
        <shape android:shape="oval">
            <size
                android:width="150dp"
                android:height="150dp" />
            <solid android:color="#142DD4BF" />
        </shape>
    </item>

    <!-- Bas gauche -->
    <item
        android:left="-120dp"
        android:bottom="-190dp">
        <shape android:shape="oval">
            <size
                android:width="360dp"
                android:height="260dp" />
            <solid android:color="#1A2F5FE6" />
        </shape>
    </item>

    <!-- Bas droite -->
    <item
        android:right="-150dp"
        android:bottom="-220dp">
        <shape android:shape="oval">
            <size
                android:width="420dp"
                android:height="300dp" />
            <solid android:color="#142DD4BF" />
        </shape>
    </item>

</layer-list>