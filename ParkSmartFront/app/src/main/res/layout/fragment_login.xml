<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth"
    android:fitsSystemWindows="true">

    <!-- Header background -->
    <View
        android:id="@+id/header_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_auth_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.30" />

    <!-- Contenu scrollable -->
    <ScrollView
        android:id="@+id/login_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/space_l">

            <!-- Header -->
            <LinearLayout
                android:id="@+id/header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="@dimen/space_s"
                android:paddingBottom="@dimen/space_m"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/iv_logo"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/login_title"
                    android:scaleType="fitCenter"
                    android:src="@mipmap/ic_smartparking_foreground" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/login_title"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/login_subtitle"
                        android:textColor="@color/ps_on_wave_muted"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Card Form -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_login"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_l"
                app:cardBackgroundColor="@color/ps_surface"
                app:cardCornerRadius="@dimen/radius_xl"
                app:cardElevation="6dp"
                app:strokeColor="@color/ps_outline"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/header"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.95">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_l">

                    <!-- Intro card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/iv_form_lock"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:contentDescription="@string/login_form_title"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/ps_primary" />

                        <TextView
                            android:id="@+id/tv_form_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/login_form_title"
                            android:textColor="@color/ps_text"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_form_desc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:lineSpacingExtra="2dp"
                            android:text="@string/login_form_desc"
                            android:textColor="@color/ps_text_muted"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Email -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.ParkSmart.TextInput"
                        android:id="@+id/til_identifier"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_l"
                        android:hint="@string/login_identifier_placeholder"
                        app:boxStrokeColor="@color/ps_outline"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:endIconMode="clear_text"
                        app:hintEnabled="true"
                        app:startIconDrawable="@drawable/ic_email"
                        app:startIconTint="@color/ps_primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_identifier"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:autofillHints="emailAddress"
                            android:importantForAutofill="yes"
                            android:inputType="textEmailAddress"
                            android:maxLength="254"
                            android:maxLines="1"
                            android:minHeight="60dp"
                            android:textColor="@color/ps_text"
                            android:textColorHint="@color/ps_text_muted" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Mot de passe -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.ParkSmart.TextInput"
                        android:id="@+id/til_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_m"
                        android:hint="@string/login_password_placeholder"
                        app:boxStrokeColor="@color/ps_outline"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:endIconMode="password_toggle"
                        app:errorIconDrawable="@null"
                        app:hintEnabled="true"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="@color/ps_primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:autofillHints="password"
                            android:importantForAutofill="yes"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:minHeight="60dp"
                            android:textColor="@color/ps_text"
                            android:textColorHint="@color/ps_text_muted" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Row actions -->
                    <CheckBox
                        android:id="@+id/cb_remember_me"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_m"
                        android:text="@string/login_remember_me"
                        android:textColor="@color/ps_text" />

                    <!-- Bouton -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_login"
                        style="@style/Widget.ParkSmart.Button"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="@dimen/space_l"
                        android:text="@string/login_button"
                        android:textColor="@color/white"
                        app:backgroundTint="@color/ps_primary"
                        app:cornerRadius="18dp"
                        app:rippleColor="@color/ps_primary_container" />

                    <!-- Mot de passe oublié -->
                    <TextView
                        android:id="@+id/tv_forgot_password"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/space_l"
                        android:background="@drawable/underline_primary"
                        android:paddingBottom="6dp"
                        android:text="@string/login_forgot_password"
                        android:textColor="@color/ps_primary"
                        android:textStyle="bold" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Footer register -->
            <LinearLayout
                android:id="@+id/footer_register"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_l"
                android:layout_marginBottom="@dimen/space_s"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/card_login"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_go_register_prefix"
                    android:textColor="@color/ps_text_muted"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_go_register"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/underline_primary"
                    android:paddingBottom="6dp"
                    android:text="@string/login_go_register_link"
                    android:textColor="@color/ps_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>