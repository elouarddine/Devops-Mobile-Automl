<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth"
    android:fitsSystemWindows="true">

    <!-- Header background -->
    <View
        android:id="@+id/header_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_auth_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.30" />

    <!-- Contenu scrollable -->
    <ScrollView
        android:id="@+id/register_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/space_m">

            <!-- Header -->
            <LinearLayout
                android:id="@+id/header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="@dimen/space_s"
                android:paddingBottom="@dimen/space_m"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/iv_logo"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:src="@mipmap/ic_smartparking_foreground"
                    android:contentDescription="@string/register_title" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/register_title"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/register_subtitle"
                        android:textColor="@color/ps_on_wave_muted"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Card Form -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_register"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_l"
                app:cardCornerRadius="@dimen/radius_xl"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/ps_surface"
                app:strokeColor="@color/ps_outline"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/header"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintWidth_percent="0.95">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_l">

                    <!-- Intro card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/iv_form_lock"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:contentDescription="@string/register_form_title"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/ps_primary" />

                        <TextView
                            android:id="@+id/tv_form_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/register_form_title"
                            android:textColor="@color/ps_text"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_form_desc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:lineSpacingExtra="2dp"
                            android:text="@string/register_form_desc"
                            android:textColor="@color/ps_text_muted"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Nom complet -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_full_name"
                        style="@style/Widget.ParkSmart.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_l"
                        android:hint="@string/register_fullname_placeholder"
                        app:hintEnabled="true"
                        app:endIconMode="clear_text"
                        app:boxStrokeColor="@color/ps_outline"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_full_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="60dp"
                            android:inputType="textPersonName"
                            android:maxLength="80"
                            android:maxLines="1"
                            android:textColor="@color/ps_text"
                            android:textColorHint="@color/ps_text_muted" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Email -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_email"
                        style="@style/Widget.ParkSmart.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_m"
                        android:hint="@string/register_email_placeholder"
                        app:hintEnabled="true"
                        app:endIconMode="clear_text"
                        app:startIconDrawable="@drawable/ic_email"
                        app:startIconTint="@color/ps_primary"
                        app:boxStrokeColor="@color/ps_outline"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:helperText="@string/register_email_rules">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:autofillHints="emailAddress"
                            android:importantForAutofill="yes"
                            android:minHeight="60dp"
                            android:inputType="textEmailAddress"
                            android:maxLength="254"
                            android:maxLines="1"
                            android:textColor="@color/ps_text"
                            android:textColorHint="@color/ps_text_muted" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Mot de passe -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_password"
                        style="@style/Widget.ParkSmart.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_m"
                        android:hint="@string/register_password_placeholder"
                        app:hintEnabled="true"
                        app:endIconMode="password_toggle"
                        app:errorIconDrawable="@null"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="@color/ps_primary"
                        app:boxStrokeColor="@color/ps_outline"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:helperText="@string/register_password_rules">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:autofillHints="password"
                            android:importantForAutofill="yes"
                            android:minHeight="60dp"
                            android:inputType="textPassword"
                            android:maxLength="64"
                            android:maxLines="1"
                            android:textColor="@color/ps_text"
                            android:textColorHint="@color/ps_text_muted" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Confirmer mot de passe -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_confirm_password"
                        style="@style/Widget.ParkSmart.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_m"
                        android:hint="@string/register_confirm_password_placeholder"
                        app:hintEnabled="true"
                        app:endIconMode="password_toggle"
                        app:errorIconDrawable="@null"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="@color/ps_primary"
                        app:boxStrokeColor="@color/ps_outline"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_confirm_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="60dp"
                            android:inputType="textPassword"
                            android:maxLength="64"
                            android:maxLines="1"
                            android:textColor="@color/ps_text"
                            android:textColorHint="@color/ps_text_muted" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Type de compte -->
                    <TextView
                        android:id="@+id/tv_account_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_m"
                        android:text="@string/register_account_type_label"
                        android:textColor="@color/ps_text"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:cardBackgroundColor="@color/ps_surface_tint"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/ps_outline"
                        app:strokeWidth="1dp">

                        <RadioGroup
                            android:id="@+id/rg_account_type"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="14dp">

                            <RadioButton
                                android:id="@+id/rb_user"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true"
                                android:text="@string/register_account_type_user"
                                android:textColor="@color/ps_text" />

                            <RadioButton
                                android:id="@+id/rb_admin"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="28dp"
                                android:text="@string/register_account_type_admin"
                                android:textColor="@color/ps_text" />
                        </RadioGroup>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Bouton register -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_register"
                        style="@style/Widget.ParkSmart.Button"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="@dimen/space_l"
                        android:text="@string/register_button"
                        android:textColor="@color/white"
                        app:backgroundTint="@color/ps_primary"
                        app:cornerRadius="18dp"
                        app:rippleColor="@color/ps_primary_container" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Footer login -->
            <LinearLayout
                android:id="@+id/footer_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_l"
                android:layout_marginBottom="@dimen/space_s"
                android:orientation="horizontal"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/card_register"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/register_already_account_prefix"
                    android:textColor="@color/ps_text_muted"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_go_login"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/register_already_account_link"
                    android:textColor="@color/ps_primary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:paddingBottom="6dp"
                    android:background="@drawable/underline_primary" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>