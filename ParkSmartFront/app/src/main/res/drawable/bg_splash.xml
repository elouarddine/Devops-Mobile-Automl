<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fond principal clair -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#F8FBFF"
                android:centerColor="#F2F7FF"
                android:endColor="#EEF4FF"
                android:type="linear" />
        </shape>
    </item>

    <!-- Halo doux derrière le logo -->
    <item
        android:left="40dp"
        android:right="40dp"
        android:top="115dp"
        android:bottom="250dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:centerX="0.5"
                android:centerY="0.35"
                android:gradientRadius="240dp"
                android:startColor="#332563EB"
                android:centerColor="#1414B8A6"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

    <!-- Nuages / masses claires -->
    <item
        android:left="-90dp"
        android:right="120dp"
        android:top="500dp"
        android:bottom="120dp">
        <shape android:shape="oval">
            <solid android:color="#CCFFFFFF"/>
        </shape>
    </item>

    <item
        android:left="140dp"
        android:right="-60dp"
        android:top="520dp"
        android:bottom="140dp">
        <shape android:shape="oval">
            <solid android:color="#B3F6FAFF"/>
        </shape>
    </item>

    <!-- Vagues basses -->
    <item
        android:left="-170dp"
        android:right="-100dp"
        android:top="650dp"
        android:bottom="-160dp">
        <shape android:shape="oval">
            <solid android:color="#1A56D6"/>
        </shape>
    </item>

    <item
        android:left="-110dp"
        android:right="0dp"
        android:top="690dp"
        android:bottom="-180dp">
        <shape android:shape="oval">
            <solid android:color="#2563EB"/>
        </shape>
    </item>

    <item
        android:left="0dp"
        android:right="-160dp"
        android:top="700dp"
        android:bottom="-175dp">
        <shape android:shape="oval">
            <solid android:color="#38BDF8"/>
        </shape>
    </item>

    <item
        android:left="110dp"
        android:right="-140dp"
        android:top="720dp"
        android:bottom="-195dp">
        <shape android:shape="oval">
            <solid android:color="#67E8F9"/>
        </shape>
    </item>

    <item
        android:left="-40dp"
        android:right="-30dp"
        android:top="675dp"
        android:bottom="-165dp">
        <shape android:shape="oval">
            <solid android:color="#66FFFFFF"/>
        </shape>
    </item>

</layer-list>