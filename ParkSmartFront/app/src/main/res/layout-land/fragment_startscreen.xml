<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guide_middle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.50" />

    <!-- Panneau droit -->
    <View
        android:id="@+id/right_panel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_auth_side_panel"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/guide_middle"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Logo -->
    <ImageView
        android:id="@+id/iv_starting_logo"
        android:layout_width="170dp"
        android:layout_height="170dp"
        android:layout_marginTop="18dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/app_name"
        android:scaleType="fitCenter"
        android:src="@mipmap/ic_smartparking_foreground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guide_middle" />

    <!-- Titre -->
    <TextView
        android:id="@+id/tv_starting_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="24dp"
        android:gravity="center"
        android:text="@string/starting_title"
        android:textColor="@color/ps_primary_dark"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/iv_starting_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guide_middle" />

    <!-- Sous-titre -->
    <TextView
        android:id="@+id/tv_starting_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="26dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="26dp"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        android:text="@string/starting_subtitle"
        android:textColor="@color/ps_text_muted"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tv_starting_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guide_middle" />

    <!-- Card user -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_user"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="22dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="22dp"
        app:cardBackgroundColor="@color/ps_surface"
        app:cardCornerRadius="18dp"
        app:cardElevation="4dp"
        app:strokeColor="@color/ps_outline"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="@id/guide_middle"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/starting_user_title"
                android:textColor="@color/ps_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/starting_user_desc"
                android:textColor="@color/ps_text_muted"
                android:textSize="13sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Card admin -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_admin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="22dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="22dp"
        app:cardBackgroundColor="@color/ps_surface"
        app:cardCornerRadius="18dp"
        app:cardElevation="4dp"
        app:strokeColor="@color/ps_outline"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/card_user"
        app:layout_constraintStart_toStartOf="@id/guide_middle"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/starting_admin_title"
                android:textColor="@color/ps_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/starting_admin_desc"
                android:textColor="@color/ps_text_muted"
                android:textSize="13sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bouton -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_start"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginBottom="8dp"
        android:text="@string/starting_button"
        android:textAllCaps="false"
        android:textColor="@color/ps_primary_dark"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@color/white"
        app:cornerRadius="18dp"
        app:elevation="0dp"
        app:rippleColor="@color/ps_primary_container"
        app:layout_constraintBottom_toTopOf="@id/tv_footer_hint"
        app:layout_constraintStart_toStartOf="@id/guide_middle"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Hint -->
    <TextView
        android:id="@+id/tv_footer_hint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="26dp"
        android:layout_marginEnd="26dp"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:text="@string/starting_footer_hint"
        android:textColor="@color/ps_on_wave_muted"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/guide_middle"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>