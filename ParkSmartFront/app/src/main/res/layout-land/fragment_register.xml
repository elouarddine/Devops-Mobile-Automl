<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guide_middle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.40" />

    <!-- Panneau gauche -->
    <View
        android:id="@+id/left_panel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_auth_side_panel_land"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guide_middle" />

    <!-- Branding gauche -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="26dp"
        android:layout_marginEnd="26dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guide_middle">

        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="145dp"
            android:layout_height="145dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/register_title"
            android:scaleType="fitCenter"
            android:src="@mipmap/ic_smartparking_foreground" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:text="@string/register_title"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="@string/register_subtitle"
            android:textColor="@color/ps_on_wave_muted"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tv_pitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:text="@string/register_form_desc"
            android:textColor="@color/ps_on_wave_muted"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Partie droite scrollable -->
    <ScrollView
        android:id="@+id/register_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/guide_middle"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_register"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/ps_surface"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/ps_outline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <!-- Intro -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/iv_form_lock"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:contentDescription="@string/register_form_title"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/ps_primary" />

                        <TextView
                            android:id="@+id/tv_form_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/register_form_title"
                            android:textColor="@color/ps_text"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_form_desc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:lineSpacingExtra="2dp"
                            android:text="@string/register_form_desc"
                            android:textColor="@color/ps_text_muted"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Nom complet -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_full_name"
                        style="@style/Widget.ParkSmart.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:hint="@string/register_fullname_placeholder"
                        app:endIconMode="clear_text"
                        app:hintEnabled="true">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_full_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"
                            android:maxLength="80"
                            android:maxLines="1"
                            android:minHeight="56dp"
                            android:textColor="@color/ps_text"
                            android:textColorHint="@color/ps_text_muted" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Email -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_email"
                        style="@style/Widget.ParkSmart.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="@string/register_email_placeholder"
                        app:endIconMode="clear_text"
                        app:hintEnabled="true"
                        app:helperText="@string/register_email_rules"
                        app:startIconDrawable="@drawable/ic_email"
                        app:startIconTint="@color/ps_primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:autofillHints="emailAddress"
                            android:importantForAutofill="yes"
                            android:inputType="textEmailAddress"
                            android:maxLength="254"
                            android:maxLines="1"
                            android:minHeight="56dp"
                            android:textColor="@color/ps_text"
                            android:textColorHint="@color/ps_text_muted" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Mot de passe -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_password"
                        style="@style/Widget.ParkSmart.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="@string/register_password_placeholder"
                        app:endIconMode="password_toggle"
                        app:hintEnabled="true"
                        app:helperText="@string/register_password_rules"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="@color/ps_primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:autofillHints="password"
                            android:importantForAutofill="yes"
                            android:inputType="textPassword"
                            android:maxLength="64"
                            android:maxLines="1"
                            android:minHeight="56dp"
                            android:textColor="@color/ps_text"
                            android:textColorHint="@color/ps_text_muted" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Confirmer mot de passe -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_confirm_password"
                        style="@style/Widget.ParkSmart.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="@string/register_confirm_password_placeholder"
                        app:endIconMode="password_toggle"
                        app:hintEnabled="true"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="@color/ps_primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_confirm_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:maxLength="64"
                            android:maxLines="1"
                            android:minHeight="56dp"
                            android:textColor="@color/ps_text"
                            android:textColorHint="@color/ps_text_muted" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/tv_account_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/register_account_type_label"
                        android:textColor="@color/ps_text"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:cardBackgroundColor="@color/ps_surface_tint"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/ps_outline"
                        app:strokeWidth="1dp">

                        <RadioGroup
                            android:id="@+id/rg_account_type"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="14dp">

                            <RadioButton
                                android:id="@+id/rb_user"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true"
                                android:text="@string/register_account_type_user"
                                android:textColor="@color/ps_text" />

                            <RadioButton
                                android:id="@+id/rb_admin"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="28dp"
                                android:text="@string/register_account_type_admin"
                                android:textColor="@color/ps_text" />
                        </RadioGroup>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_register"
                        style="@style/Widget.ParkSmart.Button"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="18dp"
                        android:text="@string/register_button"
                        android:textColor="@color/white"
                        app:backgroundTint="@color/ps_primary"
                        app:cornerRadius="18dp"
                        app:rippleColor="@color/ps_primary_container" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/footer_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/register_already_account_prefix"
                    android:textColor="@color/ps_text_muted"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_go_login"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/underline_primary"
                    android:paddingBottom="6dp"
                    android:text="@string/register_already_account_link"
                    android:textColor="@color/ps_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>