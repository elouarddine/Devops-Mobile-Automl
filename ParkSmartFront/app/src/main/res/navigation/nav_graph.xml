<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.parksmart.fragments.common.SplashFragment"
        android:label="Splash">
        <action
            android:id="@+id/action_splash_to_starting"
            app:destination="@id/startingFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/startingFragment"
        android:name="com.example.parksmart.fragments.common.StartingFragment"
        android:label="Starting">
        <action
            android:id="@+id/action_starting_to_login"
            app:destination="@id/loginFragment" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.parksmart.fragments.common.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_login_to_success"
            app:destination="@id/successLoginFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.parksmart.fragments.common.RegisterFragment"
        android:label="Register">
        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/successLoginFragment"
        android:name="com.example.parksmart.fragments.common.SuccessFragment"
        android:label="Success">
        <action
            android:id="@+id/action_success_to_user_home"
            app:destination="@id/userHomeFragment"
            app:popUpTo="@id/successLoginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_success_to_admin_home"
            app:destination="@id/adminHomeFragment"
            app:popUpTo="@id/successLoginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/userHomeFragment"
        android:name="com.example.parksmart.fragments.user.UserHomeFragment"
        android:label="user Home" />

    <fragment
        android:id="@+id/adminHomeFragment"
        android:name="com.example.parksmart.fragments.admin.AdminHomeFragment"
        android:label="Admin Home" />

</navigation>